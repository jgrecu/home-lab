machine:
  # Required for Longhorn — installs iSCSI initiator tools and loads the kernel module
  install:
    extensions:
      - image: ghcr.io/siderolabs/iscsi-tools:v0.1.6
  kernel:
    modules:
      - name: iscsi_tcp
  kubelet:
    # Bind-mounts /var/lib/longhorn into the kubelet so Longhorn can persist
    # replica data across Talos OS upgrades (Talos root is read-only/ephemeral).
    extraMounts:
      - destination: /var/lib/longhorn
        type: bind
        source: /var/lib/longhorn
        options:
          - bind
          - rshared
          - rw
