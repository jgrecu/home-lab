---
apiVersion: helm.toolkit.fluxcd.io/v2
kind: HelmRelease
metadata:
  name: radarr
spec:
  chartRef:
    kind: OCIRepository
    name: radarr
  interval: 1h
  values:
    controllers:
      radarr:
        # Must be on the same node as Transmission — they share the media-downloads
        # ReadWriteOnce PVC. Label your node: kubectl label node <name> media-node=true
        pod:
          nodeSelector:
            media-node: "true"
        containers:
          app:
            image:
              repository: ghcr.io/home-operations/radarr
              # renovate: datasource=docker depName=ghcr.io/home-operations/radarr
              tag: 5.17.2.9580
            env:
              TZ: "Europe/Madrid"
            probes:
              liveness: &probes
                enabled: true
                custom: true
                spec:
                  httpGet:
                    path: /ping
                    port: &port 7878
                  initialDelaySeconds: 30
                  periodSeconds: 30
              readiness: *probes
            securityContext:
              allowPrivilegeEscalation: false
              capabilities: { drop: ["ALL"] }
            resources:
              requests:
                cpu: 10m
              limits:
                memory: 512Mi

    persistence:
      config:
        type: persistentVolumeClaim
        storageClass: longhorn
        size: 2Gi
        accessMode: ReadWriteOnce
        globalMounts:
          - path: /config

      # Shared download staging area — same PVC as Transmission. Radarr monitors
      # /downloads for completed files and imports them to /media/movies.
      # Since downloads (Longhorn) and media (NFS) are different filesystems,
      # Radarr will copy-then-delete rather than hardlink on import. This is
      # expected behavior — set "Copy" (not "Move") in Radarr's import settings.
      downloads:
        type: persistentVolumeClaim
        existingClaim: media-downloads
        globalMounts:
          - path: /downloads

      # NFS media library — Radarr imports finished movies here.
      # Root folder in Radarr UI should be set to /media/Films
      media:
        type: persistentVolumeClaim
        storageClass: nfs-media
        size: 1Ti
        accessMode: ReadWriteMany
        globalMounts:
          - path: /media

    service:
      app:
        ports:
          http:
            port: *port
    # Internal only — accessible via ClusterIP from Jackett, Transmission, Jellyseerr
