---
# Static PV pointing to existing /videos on NAS
# Shared by Radarr, Sonarr, and Jellyfin via a single PVC
apiVersion: v1
kind: PersistentVolume
metadata:
  name: nfs-media-videos
spec:
  capacity:
    storage: 10Ti
  accessModes:
    - ReadWriteMany
  persistentVolumeReclaimPolicy: Retain
  mountOptions:
    - nfsvers=4.1
    - hard
    - noatime
  nfs:
    server: "#{ nfs_server_addr }#"
    path: /videos
---
# Shared PVC for all media services
# Radarr, Sonarr, and Jellyfin all mount this to access /videos
apiVersion: v1
kind: PersistentVolumeClaim
metadata:
  name: media-library
  namespace: storage
spec:
  accessModes:
    - ReadWriteMany
  storageClassName: ""  # Empty to use static PV
  volumeName: nfs-media-videos  # Bind to static PV above
  resources:
    requests:
      storage: 10Ti
