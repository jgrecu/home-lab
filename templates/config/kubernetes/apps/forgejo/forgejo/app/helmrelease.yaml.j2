---
apiVersion: helm.toolkit.fluxcd.io/v2
kind: HelmRelease
metadata:
  name: forgejo
spec:
  chartRef:
    kind: OCIRepository
    name: forgejo
  interval: 1h
  values:
    gitea:
      admin:
        username: admin
        existingSecret: forgejo-secret
        existingSecretKey: admin-password
        email: "#{ forgejo_admin_email }#"
      config:
        server:
          DOMAIN: "forgejo.${SECRET_DOMAIN}"
          ROOT_URL: "https://forgejo.${SECRET_DOMAIN}"
          # SSH cloning requires a separate TCP load balancer outside this
          # template (Cloudflare Tunnel does not support raw TCP on port 22).
          # Use HTTPS for git remotes: https://forgejo.yourdomain.com/user/repo
          SSH_DOMAIN: "forgejo.${SECRET_DOMAIN}"
          SSH_PORT: 22
          DISABLE_SSH: "false"
        database:
          DB_TYPE: postgres
          # CloudNativePG creates a service named <cluster>-rw for the primary
          HOST: "forgejo-postgres-rw:5432"
          NAME: forgejo
          USER: forgejo
        packages:
          # Enables the built-in container registry.
          # Push/pull images: forgejo.${SECRET_DOMAIN}/username/image:tag
          ENABLED: "true"
        actions:
          # Enables Forgejo Actions (GitHub Actions-compatible CI/CD).
          # Runners must register separately — see forgejo-runner app.
          ENABLED: "true"
          DEFAULT_ACTIONS_URL: "https://code.forgejo.org"
      # Inject the database password from the CNPG-generated secret.
      # CNPG creates "forgejo-postgres-app" automatically when the Cluster
      # resource is applied — no password to manage manually.
      additionalConfigFromEnvs:
        - name: GITEA__database__PASSWD
          valueFrom:
            secretKeyRef:
              name: forgejo-postgres-app
              key: password

    persistence:
      enabled: true
      storageClass: longhorn
      size: 20Gi

    # PostgreSQL is managed by CloudNativePG — disable the subcharts
    postgresql:
      enabled: false
    postgresql-ha:
      enabled: false

    route:
      enabled: true
      # Exposed externally so you can push/pull code from anywhere
      hostnames: ["forgejo.${SECRET_DOMAIN}"]
      parentRefs:
        - name: envoy-external
          namespace: network
          sectionName: https
