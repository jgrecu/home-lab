---
# Restic repository secret for Immich database backups
# This secret contains S3 credentials and Restic password
apiVersion: v1
kind: Secret
metadata:
  name: immich-db-restic-secret
  namespace: entertainment
type: Opaque
stringData:
  # S3 repository URL pointing to Garage
  RESTIC_REPOSITORY: s3:https://garage.#{ cloudflare_domain }#/volsync-backups/immich-db

  # Restic encryption password
  # Generate with: openssl rand -base64 32
  RESTIC_PASSWORD: "#{ volsync_restic_password }#"

  # Garage S3 credentials
  AWS_ACCESS_KEY_ID: "#{ volsync_s3_access_key }#"
  AWS_SECRET_ACCESS_KEY: "#{ volsync_s3_secret_key }#"
