---
# Immich requires PostgreSQL with VectorChord extension for its
# AI/vector search features (face clustering, CLIP semantic search).
# We use the cloudnative-vectorchord image — same CNPG operator,
# just a custom image that includes VectorChord + pgvector.
apiVersion: postgresql.cnpg.io/v1
kind: Cluster
metadata:
  name: immich-postgres
spec:
  # Custom image with VectorChord extension (successor to pgvecto.rs)
  imageName: ghcr.io/tensorchord/cloudnative-vectorchord:16-1.1.1
  # 2 instances = 1 primary + 1 replica for high availability.
  # CNPG operator automatically enables soft pod anti-affinity to spread across nodes.
  # Provides automatic failover and read scaling.
  instances: 2
  resources:
    requests:
      cpu: 250m
      memory: 1Gi
    limits:
      memory: 4Gi
  storage:
    storageClass: longhorn-single
    size: 10Gi
  postgresql:
    shared_preload_libraries:
      - "vchord.so"
  bootstrap:
    initdb:
      database: immich
      owner: immich
      # Enable required extensions after the database is created
      postInitApplicationSQL:
        - CREATE EXTENSION IF NOT EXISTS vchord CASCADE;
        - CREATE EXTENSION IF NOT EXISTS earthdistance CASCADE;
  # Continuous WAL archiving to SeaweedFS S3
  # Provides point-in-time recovery with ~5 minute RPO
  backup:
    barmanObjectStore:
      destinationPath: "s3://cnpg-backups/immich-postgres/"
      endpointURL: "http://seaweedfs-filer.storage.svc.cluster.local:8333"
      s3Credentials:
        accessKeyId:
          name: cnpg-backup-secret
          key: ACCESS_KEY_ID
        secretAccessKey:
          name: cnpg-backup-secret
          key: ACCESS_SECRET_KEY
      wal:
        compression: gzip
    retentionPolicy: "180d"
