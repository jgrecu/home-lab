---
apiVersion: gateway.networking.k8s.io/v1
kind: HTTPRoute
metadata:
  name: grimmory
  annotations:
    gethomepage.dev/enabled: "true"
    gethomepage.dev/group: Entertainment
    gethomepage.dev/name: Grimmory
    gethomepage.dev/icon: mdi-bookshelf
    gethomepage.dev/description: Digital book library
    gethomepage.dev/href: https://grimmory.${SECRET_DOMAIN}
spec:
  hostnames: ["grimmory.${SECRET_DOMAIN}"]
  parentRefs:
    - name: envoy-external
      namespace: network
      sectionName: https
  rules:
    - backendRefs:
        - name: grimmory
          port: 6060
