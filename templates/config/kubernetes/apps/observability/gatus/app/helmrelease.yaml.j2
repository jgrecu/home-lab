---
apiVersion: helm.toolkit.fluxcd.io/v2
kind: HelmRelease
metadata:
  name: gatus
spec:
  chartRef:
    kind: OCIRepository
    name: gatus
  interval: 1h
  values:
    controllers:
      gatus:
        strategy: RollingUpdate
        containers:
          app:
            image:
              repository: ghcr.io/twin/gatus
              tag: v5.35.0
            env:
              # Tell Gatus where its config file lives
              GATUS_CONFIG_PATH: /config/config.yaml
            probes:
              liveness: &probes
                enabled: true
                custom: true
                spec:
                  httpGet:
                    path: /health
                    port: &port 8080
                  initialDelaySeconds: 10
                  periodSeconds: 30
              readiness: *probes
            securityContext:
              allowPrivilegeEscalation: false
              capabilities: { drop: ["ALL"] }
              readOnlyRootFilesystem: true
            resources:
              requests:
                cpu: 10m
              limits:
                memory: 128Mi

    configMaps:
      config:
        data:
          config.yaml: |
            # Gatus status page configuration.
            # Add an entry per service you want to monitor.
            # Gatus checks each endpoint on the defined interval and
            # shows a status page with uptime history and response times.
            #
            # Full docs: https://github.com/TwiN/gatus#configuration

            web:
              port: 8080

            storage:
              type: sqlite
              path: /data/gatus.db

            endpoints:
              # CloudFlare IP Blocking Detection (LaLiga anti-piracy)
              # Spanish ISPs block ~3,000 CloudFlare IPs during matches
              - name: CloudFlare Infrastructure
                group: CloudFlare
                url: "https://1.1.1.1"
                interval: 2m
                conditions:
                  - "[STATUS] == 200"
                  - "[RESPONSE_TIME] < 2000"

              - name: CloudFlare API
                group: CloudFlare
                url: "https://api.cloudflare.com/client/v4/ips"
                interval: 2m
                conditions:
                  - "[STATUS] == 200"
                  - "[RESPONSE_TIME] < 3000"

              - name: CloudFlare Tunnel
                group: CloudFlare
                url: "http://cloudflare-tunnel.network.svc.cluster.local:8080/ready"
                interval: 2m
                conditions:
                  - "[STATUS] == 200"

              - name: Nextcloud (via CloudFlare)
                group: CloudFlare
                url: "https://nextcloud.${SECRET_DOMAIN}/status.php"
                interval: 2m
                conditions:
                  - "[STATUS] == 200"
                  - "[BODY].installed == true"
                  - "[RESPONSE_TIME] < 5000"

              - name: Forgejo (via CloudFlare)
                group: CloudFlare
                url: "https://forgejo.${SECRET_DOMAIN}"
                interval: 2m
                conditions:
                  - "[STATUS] == 200"
                  - "[RESPONSE_TIME] < 5000"

              - name: Docker Hub
                group: CloudFlare
                url: "https://registry-1.docker.io/v2/"
                interval: 2m
                conditions:
                  - "[STATUS] == 200 || [STATUS] == 401"
                  - "[RESPONSE_TIME] < 5000"

              - name: CloudFlare Status
                group: CloudFlare
                url: "https://www.cloudflarestatus.com"
                interval: 5m
                conditions:
                  - "[STATUS] == 200"
                  - "[RESPONSE_TIME] < 3000"

              # Observability
              - name: Grafana
                group: Observability
                url: "http://grafana.observability.svc.cluster.local"
                interval: 5m
                conditions:
                  - "[STATUS] == 200"

              # Internal Services
              - name: Homepage
                group: Internal
                url: "http://homepage.default.svc.cluster.local:3000"
                interval: 5m
                conditions:
                  - "[STATUS] == 200"

              # External Services
              - name: Immich
                group: External
                url: "https://immich.${SECRET_DOMAIN}"
                interval: 5m
                conditions:
                  - "[STATUS] == 200"
                  - "[RESPONSE_TIME] < 3000"

              - name: Nextcloud
                group: External
                url: "https://nextcloud.${SECRET_DOMAIN}/status.php"
                interval: 5m
                conditions:
                  - "[STATUS] == 200"
                  - "[BODY].installed == true"

              - name: Forgejo
                group: External
                url: "https://forgejo.${SECRET_DOMAIN}"
                interval: 5m
                conditions:
                  - "[STATUS] == 200"

              - name: Kavita
                group: External
                url: "https://kavita.${SECRET_DOMAIN}"
                interval: 5m
                conditions:
                  - "[STATUS] == 200"

              # Downloads - Media Management
              - name: Sonarr
                group: Downloads
                url: "https://sonarr.${SECRET_DOMAIN}/ping"
                interval: 5m
                conditions:
                  - "[STATUS] == 200"

              - name: Radarr
                group: Downloads
                url: "https://radarr.${SECRET_DOMAIN}/ping"
                interval: 5m
                conditions:
                  - "[STATUS] == 200"

              - name: Prowlarr
                group: Downloads
                url: "https://prowlarr.${SECRET_DOMAIN}"
                interval: 5m
                conditions:
                  - "[STATUS] == 200"

              - name: Bazarr
                group: Downloads
                url: "https://bazarr.${SECRET_DOMAIN}"
                interval: 5m
                conditions:
                  - "[STATUS] == 200"

              - name: Transmission
                group: Downloads
                url: "https://transmission.${SECRET_DOMAIN}"
                interval: 5m
                conditions:
                  - "[STATUS] == 200"

              - name: Autobrr
                group: Downloads
                url: "https://autobrr.${SECRET_DOMAIN}/api/healthz/liveness"
                interval: 5m
                conditions:
                  - "[STATUS] == 200"

              - name: Jackett
                group: Downloads
                url: "http://jackett.downloads.svc.cluster.local:9117"
                interval: 5m
                conditions:
                  - "[STATUS] == 200"

              # Entertainment - Media Consumption
              - name: Jellyfin
                group: Entertainment
                url: "https://jellyfin.${SECRET_DOMAIN}/health"
                interval: 5m
                conditions:
                  - "[STATUS] == 200"
                  - "[RESPONSE_TIME] < 3000"

              - name: Seerr
                group: Entertainment
                url: "https://seerr.${SECRET_DOMAIN}/api/v1/status"
                interval: 5m
                conditions:
                  - "[STATUS] == 200"

              # Home Automation
              - name: Home Assistant
                group: Home Automation
                url: "https://home-assistant.${SECRET_DOMAIN}"
                interval: 5m
                conditions:
                  - "[STATUS] == 200"

              # Infrastructure
              - name: Pi-hole
                group: Infrastructure
                url: "https://pihole.${SECRET_DOMAIN}/admin/"
                interval: 5m
                conditions:
                  - "[STATUS] == 200"

              - name: NFS Media Server
                group: Infrastructure
                url: "192.168.1.37"
                interval: 3m
                tcp:
                  port: 2049
                conditions:
                  - "[CONNECTED] == true"

              - name: Dragonfly Cache
                group: Infrastructure
                url: "dragonfly.database-system.svc.cluster.local:6379"
                interval: 3m
                tcp:
                  port: 6379
                conditions:
                  - "[CONNECTED] == true"

              - name: Garage S3
                group: Infrastructure
                url: "http://garage-s3.storage.svc.cluster.local:3900"
                interval: 3m
                conditions:
                  - "[STATUS] == 200"

              - name: Garage Health
                group: Infrastructure
                url: "http://garage.storage.svc.cluster.local:3903/health"
                interval: 3m
                conditions:
                  - "[STATUS] == 200"

    persistence:
      # Config file from the ConfigMap defined above
      config:
        type: configMap
        identifier: config
        globalMounts:
          - path: /config
            readOnly: true
      # SQLite database for storing uptime history
      data:
        type: persistentVolumeClaim
        storageClass: longhorn
        size: 1Gi
        accessMode: ReadWriteOnce
        globalMounts:
          - path: /data

    service:
      app:
        ports:
          http:
            port: *port

    route:
      app:
        annotations:
          gethomepage.dev/enabled: "true"
          gethomepage.dev/name: "Gatus"
          gethomepage.dev/group: "Observability"
          gethomepage.dev/description: "Status page and uptime monitoring"
          gethomepage.dev/icon: "gatus.png"
          gethomepage.dev/href: "https://gatus.${SECRET_DOMAIN}"
        hostnames: ["gatus.${SECRET_DOMAIN}"]
        parentRefs:
          - name: envoy-internal
            namespace: network
            sectionName: https
        rules:
          - backendRefs:
              - identifier: app
                port: *port
