---
apiVersion: v1
kind: Secret
metadata:
  name: grafana-restic-secret
  namespace: observability
type: Opaque
stringData:
  RESTIC_REPOSITORY: s3:https://garage.#{ cloudflare_domain }#/volsync-backups/grafana
  RESTIC_PASSWORD: "#{ volsync_restic_password }#"
  AWS_ACCESS_KEY_ID: "#{ volsync_s3_access_key }#"
  AWS_SECRET_ACCESS_KEY: "#{ volsync_s3_secret_key }#"
