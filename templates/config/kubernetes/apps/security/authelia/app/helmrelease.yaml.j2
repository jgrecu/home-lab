---
apiVersion: helm.toolkit.fluxcd.io/v2
kind: HelmRelease
metadata:
  name: authelia
  namespace: security
spec:
  chartRef:
    kind: OCIRepository
    name: authelia
  interval: 1h
  values:
    controllers:
      authelia:
        replicas: 1
        strategy: Recreate
        annotations:
          reloader.stakater.com/auto: "true"
        pod:
          securityContext:
            runAsUser: 568
            runAsGroup: 568
            fsGroup: 568
            fsGroupChangePolicy: OnRootMismatch
        containers:
          app:
            image:
              repository: ghcr.io/authelia/authelia
              tag: 4.38.16
            env:
              AUTHELIA_SERVER_ADDRESS: tcp://0.0.0.0:9091
              AUTHELIA_TELEMETRY_METRICS_ENABLED: "true"
              AUTHELIA_TELEMETRY_METRICS_ADDRESS: tcp://0.0.0.0:8080
              AUTHELIA_THEME: dark
              X_AUTHELIA_CONFIG: /config/configuration.yml
            envFrom:
              - secretRef:
                  name: authelia-secrets
            probes:
              liveness:
                enabled: true
                custom: true
                spec:
                  httpGet:
                    path: /api/health
                    port: 9091
                  initialDelaySeconds: 10
                  periodSeconds: 10
              readiness:
                enabled: true
                custom: true
                spec:
                  httpGet:
                    path: /api/health
                    port: 9091
                  initialDelaySeconds: 10
                  periodSeconds: 10
            resources:
              requests:
                cpu: 10m
                memory: 128Mi
              limits:
                memory: 256Mi

    persistence:
      config:
        type: persistentVolumeClaim
        storageClass: longhorn
        size: 1Gi
        accessMode: ReadWriteOnce
        globalMounts:
          - path: /config
      configuration:
        type: configMap
        name: authelia-config
        globalMounts:
          - path: /config/configuration.yml
            subPath: configuration.yml
            readOnly: true
      users:
        type: secret
        name: authelia-users
        globalMounts:
          - path: /config/users_database.yml
            subPath: users_database.yml
            readOnly: true

    service:
      app:
        controller: authelia
        ports:
          http:
            port: 9091
          metrics:
            port: 8080

    route:
      app:
        hostnames: ["auth.#{cloudflare_domain}#"]
        parentRefs:
          - name: envoy-external
            namespace: network
            sectionName: https
        rules:
          - backendRefs:
              - name: authelia
                port: 9091
        annotations:
          external-dns.alpha.kubernetes.io/target: #{cloudflare_domain}#
          gethomepage.dev/enabled: "true"
          gethomepage.dev/group: Security
          gethomepage.dev/name: Authelia
          gethomepage.dev/icon: authelia.svg
