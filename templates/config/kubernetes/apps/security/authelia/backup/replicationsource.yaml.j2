---
apiVersion: volsync.backube/v1alpha1
kind: ReplicationSource
metadata:
  name: authelia-config-backup
  namespace: security
spec:
  sourcePVC: authelia
  trigger:
    schedule: "15 3 * * *"  # 3:15 AM daily
  restic:
    copyMethod: Snapshot
    pruneIntervalDays: 7
    repository: authelia-restic-secret
    moverSecurityContext:
      runAsUser: 568
      runAsGroup: 568
      fsGroup: 568
    retain:
      daily: 7
      weekly: 8
      monthly: 6
---
apiVersion: v1
kind: Secret
metadata:
  name: authelia-restic-secret
  namespace: security
type: Opaque
stringData:
  RESTIC_REPOSITORY: "s3:http://garage-s3.storage.svc.cluster.local:3900/volsync-backups/authelia-config"
  RESTIC_PASSWORD: "#{garage_s3_secret_access_key}#"
  AWS_ACCESS_KEY_ID: "#{garage_s3_access_key_id}#"
  AWS_SECRET_ACCESS_KEY: "#{garage_s3_secret_access_key}#"
