---
apiVersion: kustomize.toolkit.fluxcd.io/v1
kind: Kustomization
metadata:
  name: nextcloud
spec:
  dependsOn:
    - name: cloudnative-pg
    - name: longhorn
    - name: csi-driver-nfs
  interval: 1h
  path: ./kubernetes/apps/cloud/nextcloud/app
  postBuild:
    substituteFrom:
      - name: cluster-secrets
        kind: Secret
  prune: true
  sourceRef:
    kind: GitRepository
    name: flux-system
    namespace: flux-system
  targetNamespace: cloud
  wait: false
