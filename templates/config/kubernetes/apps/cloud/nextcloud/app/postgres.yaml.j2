---
# CloudNativePG manages this PostgreSQL instance.
# The operator automatically creates a secret named "nextcloud-postgres-app"
# containing: username, password, host, port, dbname, uri.
# Nextcloud reads the password directly from that secret.
apiVersion: postgresql.cnpg.io/v1
kind: Cluster
metadata:
  name: nextcloud-postgres
spec:
  # 2 instances = primary + 1 standby on a different node.
  # longhorn-single: Longhorn stores 1 replica per instance.
  # CNPG replication handles HA — no need for Longhorn to duplicate.
  instances: 2
  storage:
    storageClass: longhorn-single
    size: 10Gi
  bootstrap:
    initdb:
      database: nextcloud
      owner: nextcloud
  # Continuous WAL archiving to SeaweedFS S3
  # Provides point-in-time recovery with ~5 minute RPO
  backup:
    barmanObjectStore:
      destinationPath: "s3://cnpg-backups/nextcloud-postgres/"
      endpointURL: "http://seaweedfs-filer.storage.svc.cluster.local:8333"
      s3Credentials:
        accessKeyId:
          name: cnpg-backup-secret
          key: ACCESS_KEY_ID
        secretAccessKey:
          name: cnpg-backup-secret
          key: ACCESS_SECRET_KEY
      wal:
        compression: gzip
    retentionPolicy: "180d"
